<%- include('partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">

<style>
    .form-row {
        display: flex;
        gap: 20px;
        margin-bottom: 15px;
    }
    .form-row .form-group {
        flex: 1; /* Faz os campos dividirem o espaço igualmente */
        margin-bottom: 0; 
    }
</style>

<main class="hero">
    <h1>Solicitação de Atendimento Apométrico</h1>
    <form action="/atendimento/solicitacao" method="POST" class="form-container">
        
        <div class="form-row">
            <div class="form-group">
                <label for="data">Data do Atendimento:</label>
                <input type="date" id="data" name="data" 
                       value="<%= new Date().toLocaleDateString('en-CA') %>" required>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group"  style="flex: 1;">
                <label for="cpf_assistido">CPF do Assistido:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" required>
            </div>
            <div class="form-group"> <label for="nome">Nome de quem será atendido:</label>
                <input type="text" id="nome" name="nome" required>
            </div>

        </div>

        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label for="sexo">Sexo:</label>
                <input type="text" id="sexo" name="sexo">
            </div>
            <div class="form-group" style="flex: 2;">
                <label for="data_nascimento">Data de Nascimento:</label>
                <input type="date" id="data_nascimento" name="data_nascimento">
            </div>
            <div class="form-group">
                <label for="religiao">Religião:</label>
                <input type="text" id="religiao" name="religiao">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label for="cidade">Cidade:</label>
                <input type="text" id="cidade" name="cidade">
            </div>
            <div class="form-group" style="flex: 2;" >
                <label for="uf">UF:</label>
                <input type="text" id="uf" name="uf" maxlength="2">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label for="email">email:</label>
                <input type="email" id="email" name="email">
            </div>
            <div class="form-group" style="flex: 2;">
                <label for="telefone">Telefone/Whatsapp:</label>
                <input type="tel" id="telefone" name="telefone">
            </div>

            <div class="form-group"  style="flex: 3;">
                <label for="atendimento_por">Sendo atendido pela:</label>
                <select id="atendimento_por" name="atendimento_por">
                    <option value="Primeira vez" selected>Primeira vez</option>
                    <option value="Segunda vez" >Segunda vez</option>
                    <option value="Terceira vez" >Terceira vez</option>
                    <option value="Quarta vez" >Quarta vez</option>
                    <option value="Quinta vez" >Quinta vez</option>
                    <option value="Já passei mais vezes" >Já passei mais vezes</option>
                </select>
            </div>
        </div><br><br>
        <div class="form-group" style="flex: 1;">
            <label for="queixa">Breve descrição da queixa/motivo:</label>
            <textarea id="queixa" name="queixa" rows="3"></textarea>
        </div><br>

        <div class="form-group">
            <label for="subir_escada">Pode subir escada:</label>
            <select id="subir_escada" name="subir_escada">
                <option value="Sim" selected>Sim</option>
                <option value="Não">Não</option>
            </select>
        </div><br><br>

        <button type="submit" class="btn-atender btn-success" <%= typeof bloqueado !== 'undefined' && bloqueado ? 'disabled' : '' %>>
            <%= typeof bloqueado !== 'undefined' && bloqueado ? 'Limite Excedido para Hoje' : 'Registrar Solicitação' %>
        </button>
    </form>
    <div id="historico-container" style="margin-top: 20px; display: none;">
    <h3>Últimos Atendimentos</h3>
    <table id="tabela-historico" class="form-container">
        <thead>
            <tr>
                <th>Data</th>
                <th>Queixa</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

<script>
    // Lógica para buscar histórico ao digitar o CPF
document.getElementById('cpf_assistido').addEventListener('blur', async (e) => {
    const cpf = e.target.value.replace(/\D/g, ''); // Remove pontos/traços
    if (cpf.length >= 11) {
        // 1. BUSCA O HISTÓRICO (Já estava funcionando)
        const respHist = await fetch(`/atendimento/historico/${cpf}`);
        const historico = await respHist.json();
        
        const container = document.getElementById('historico-container');
        const tbody = document.querySelector('#tabela-historico tbody');
        tbody.innerHTML = '';
        if (historico.length > 0) {
            container.style.display = 'block';
            historico.forEach(h => {
                const data = new Date(h.data_pedido).toLocaleDateString('pt-BR');
                tbody.innerHTML += `<tr><td>${data}</td><td>${h.queixa_motivo}</td><td>${h.status}</td></tr>`;
            });
        }

        // 2. BUSCA DADOS DO ASSISTIDO (Para preencher os campos)
        const respDados = await fetch(`/api/dados-assistido/${cpf}`);
        if (respDados.ok) {
            const assistido = await respDados.json();
            console.log("Dados recebidos:", assistido); // Para você conferir no F12

            if (assistido) {
                // CORREÇÃO DOS NOMES DOS CAMPOS (Adicionando _assistido)
                document.getElementById('nome').value = assistido.nome_assistido || '';
                document.getElementById('sexo').value = assistido.sexo_assistido || '';
                document.getElementById('religiao').value = assistido.religiao_assistido || '';
                document.getElementById('cidade').value = assistido.cidade_assistido || '';
                document.getElementById('uf').value = assistido.uf_assistido || '';
                document.getElementById('email').value = assistido.email_assistido || '';
                document.getElementById('telefone').value = assistido.telefone_assistido || '';
                
                if (assistido.data_nascimento_assistido) {
                    // Formata a data para o input date (YYYY-MM-DD)
                    const dataIso = new Date(assistido.data_nascimento_assistido).toISOString().split('T')[0];
                    document.getElementById('data_nascimento').value = dataIso;
                }
            }
        }
    }
});
</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const form = document.querySelector('form');
    
    form.addEventListener('submit', async (e) => {
        e.preventDefault(); // Bloqueia o recarregamento da página 

        const formData = new FormData(form);
        const dados = Object.fromEntries(formData.entries());

        try {
            const resposta = await fetch('/atendimento/solicitacao', { // Rota sincronizada [cite: 39]
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });

            const resultado = await resposta.json();

            if (resultado.status === 'sucesso') {
                Swal.fire({
                    title: resultado.posicao <= resultado.limite ? '✅ Confirmado!' : '⏳ Lista de Espera',
                    text: `Sua posição é ${resultado.posicao}/${resultado.limite}.`,
                    icon: resultado.posicao <= resultado.limite ? 'success' : 'warning',
                    confirmButtonText: 'Entendido',
                    showCancelButton: true,
                    cancelButtonText: 'Início'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.reload(); // [cite: 42]
                    } else {
                        window.location.href = '/'; // [cite: 43]
                    }
                });
            } else if (resultado.status === 'duplicado') {
                // ALERTA PARA SOLICITAÇÃO REPETIDA
                Swal.fire({
                    title: 'Solicitação já realizada!',
                    text: resultado.mensagem,
                    icon: 'warning',
                    confirmButtonText: 'Entendido'
                });
/*             } else if (resultado.status === 'nao_encontrado') {
                Swal.fire({
                    title: 'Assistido não encontrado',
                    text: 'O CPF informado não possui cadastro. Deseja cadastrar agora?',
                    icon: 'error',
                    showCancelButton: true,
                    confirmButtonText: 'Ir para Cadastro'
                }).then((result) => {
                    if (result.isConfirmed) window.location.href = '/cadastro'; // [cite: 46]
                }); */
            }
        } catch (error) {
            console.error('Erro:', error);
            Swal.fire('Erro!', 'Falha ao conectar com o servidor.', 'error'); // [cite: 48]
        }
    });
</script>
</main>
<%- include('partials/footer') %>