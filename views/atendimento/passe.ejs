<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">
<main class="hero">
    <h1>Ficha de Atendimento - Passe</h1>
    
    <form action="/atendimento/salvar" method="POST" class="form-container" id="atendimentoForm">
        <input type="hidden" name="tipo" value="passe">
        
        <div class="form-row">
            <div class="form-group">
                <label>Data:</label>
                <input type="date" name="data" id="campo_data" required>
            </div>
            <div class="form-group flex-2">
                <label>CPF:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" placeholder="Apenas números" required autocomplete="off">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Nome:</label>
                <input type="text" name="nome_assistido" id="campo_nome" required>
            </div>

            <div class="form-group">
                <label>Terapeuta Responsável:</label>
                <input type="text" name="voluntario" required>
            </div>
        </div>

        <div class="form-group">
            <label>Observações:</label>
            <textarea name="observacoes" rows="4"></textarea>
        </div><br><br>

        <button type="submit" class="btn-primary">Finalizar o Atendimento</button>
    </form>

    <section class="historico-section" style="margin-top: 30px;">
        <h2>Histórico de Passes</h2>
        <div id="historicoContainer" style="background: #fff; padding: 15px; border: 1px solid #ddd; border-radius: 8px;">
            <p>Digite o CPF para carregar o histórico.</p>
        </div>
    </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // 1. Data automática
  document.getElementById('campo_data').value = new Date().toISOString().split('T')[0];

  // 2. Função para desenhar a tabela
  const renderizarTabela = (lista) => {
    const container = document.getElementById('historicoContainer');
    if (!lista || lista.length === 0) {
      container.innerHTML = '<p>Nenhum histórico de Passe encontrado.</p>';
      return;
    }

    let html = '<table style="width:100%; border-collapse: collapse; margin-top:10px;">';
    html += '<tr style="background:#f4f4f4"><th style="padding:8px; border:1px solid #ddd;">Data</th><th style="padding:8px; border:1px solid #ddd;">Terapeuta</th><th style="padding:8px; border:1px solid #ddd;">Obs</th></tr>';
    lista.forEach(item => {
      const d = new Date(item.data).toLocaleDateString('pt-BR');
      html += `<tr>
        <td style="border:1px solid #ddd; padding:8px;">${d}</td>
        <td style="border:1px solid #ddd; padding:8px;">${item.voluntario || ''}</td>
        <td style="border:1px solid #ddd; padding:8px;">${item.observacoes || ''}</td>
      </tr>`;
    });
    html += '</table>';
    container.innerHTML = html;
  };

  // 3. Busca de Nome e Histórico
  document.getElementById('cpf_assistido').addEventListener('blur', async function() {
    const cpf = this.value.trim().replace(/\D/g, '');
    if (cpf.length < 11) return;

    try {
      // Busca Nome
      const resDados = await fetch(`/api/dados-assistido/${cpf}`).then(r => r.json());
      document.getElementById('campo_nome').value = resDados.nome || "";

      // Busca Histórico (tipo passe)
      const resHist = await fetch(`/api/historico/passe/${cpf}`).then(r => r.json());
      renderizarTabela(resHist.historico || []);
    } catch (err) {
      console.error('Erro na busca:', err);
    }
  });

  // 4. Envio via AJAX
  document.getElementById('atendimentoForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button');
    btn.disabled = true;

    try {
      const body = new URLSearchParams(new FormData(form));
      const resp = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body
      });

      if (!resp.ok) throw new Error('Erro ao salvar no servidor');

      await Swal.fire('Sucesso', 'Atendimento de Passe salvo!', 'success');
      window.location.reload();
    } catch (err) {
      Swal.fire('Erro', err.message, 'error');
      btn.disabled = false;
    }
  });
</script>
<%- include('../partials/footer') %>