<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">
<main class="hero">
    <h1>Ficha de Atendimento - Auriculo</h1>
    
    <form action="/atendimento/auriculo" method="POST" class="form-container">
        <input type="hidden" name="tipo" value="auriculo">
        
        <div class="form-row">
            <div class="form-group">
                <label>Data:</label>
                <input type="date" name="data" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            <div class="form-group flex-2">
                <label>CPF:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" required>
            </div>
        </div>
        <div class="form-row">
        <div class="form-group">
            <label>Nome:</label>
            <input type="text" name="nome_assistido" required>
        </div>

        <div class="form-group">
            <label>Terapeuta Responsável:</label>
            <input type="text" name="voluntario" required>
        </div>
        </div>
        <div class="form-group">
            <label>Observações:</label>
            <textarea name="observacoes" rows="4"></textarea>
        </div><br><br>

        <button type="submit" class="btn-submit">Salvar Atendimento</button>
    </form>

<section class="historico" style="margin-top: 40px;">
        <h2>Últimos 12 Atendimentos de Auriculo</h2>
        <div id="container-historico">
            <p style="color: #888;">Digite o CPF para carregar o histórico.</p>
        </div>
    </section>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
const cpfInput = document.getElementById("cpf_assistido");
const container = document.getElementById("container-historico");
const nomeInput = document.querySelector('input[name="nome_assistido"]');

function escapeHtml(str) {
  return String(str ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#039;");
}

function renderHistorico(historico) {

  if (!Array.isArray(historico) || historico.length === 0) {
    container.innerHTML =
      '<p style="color:#888;">Nenhum histórico de apometria encontrado para este CPF.</p>';
    return;
  }

  let html = `
  <table style="width:100%;border-collapse:collapse;margin-top:15px;">
  <thead>
  <tr style="background:#f8f9fa;text-align:left;">
  <th style="padding:12px;border:1px solid #ddd;">Data</th>
  <th style="padding:12px;border:1px solid #ddd;">Terapeuta</th>
  <th style="padding:12px;border:1px solid #ddd;">Observações</th>
  </tr>
  </thead>
  <tbody>`;

  historico.forEach(item => {

    const dataF = item?.data
      ? new Date(item.data).toLocaleDateString("pt-BR", { timeZone: 'UTC' })
      : "";

    html += `
      <tr>
      <td style="padding:12px;border:1px solid #ddd;">${escapeHtml(dataF)}</td>
      <td style="padding:12px;border:1px solid #ddd;">${escapeHtml(item.voluntario || "Não informado")}</td>
      <td style="padding:12px;border:1px solid #ddd;">${escapeHtml(item.observacoes || "")}</td>
      </tr>`;
  });

  html += "</tbody></table>";

  container.innerHTML = html;
}

async function buscar(cpf) {

  container.innerHTML = "<p>Buscando histórico de apometria...</p>";

  try {

    const [respAssistido, respHistorico] = await Promise.all([
      fetch(`/api/assistido/${cpf}`),
      fetch(`/api/historico/auriculo/${cpf}`)
    ]);

    if (respAssistido.ok && nomeInput) {
      const assistido = await respAssistido.json();
      nomeInput.value = assistido?.nome || "";
    }

    const payload = await respHistorico.json();

    const historico = Array.isArray(payload)
      ? payload
      : payload.historico || [];

    renderHistorico(historico);

  } catch (err) {

    console.error("Erro na busca:", err);

    container.innerHTML = `
      <p style="color:red;">
      Erro ao carregar histórico.<br>
      <small>${escapeHtml(err.message || err)}</small>
      </p>`;
  }
}

cpfInput.addEventListener("blur", () => {

  const cpf = cpfInput.value.trim();

  if (!cpf) return;

  buscar(cpf);

});
</script>
<script>
  const form = document.querySelector('form.form-container');
  const btnSubmit = form?.querySelector('button[type="submit"]');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // evita duplo clique
      if (btnSubmit) {
        btnSubmit.disabled = true;
        btnSubmit.textContent = "Salvando...";
      }

      try {
        // envia no formato que o express.urlencoded entende
        const body = new URLSearchParams(new FormData(form));

        const resp = await fetch(form.action, {
          method: "POST",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8"
          },
          body
        });

        if (!resp.ok) {
          const txt = await resp.text().catch(() => "");
          throw new Error(txt || `HTTP ${resp.status}`);
        }

        await Swal.fire({
          icon: "success",
          title: "Atendimento salvo com sucesso!",
          text: "Clique em OK para iniciar um novo atendimento de Aurículo.",
          confirmButtonText: "OK"
        });

        // sua página abre aqui:
        window.location.href = "/atendimento/auriculo";

      } catch (err) {
        console.error("Erro ao salvar:", err);

        await Swal.fire({
          icon: "error",
          title: "Erro ao salvar",
          text: err?.message || "Ocorreu um erro ao salvar o atendimento."
        });

      } finally {
        if (btnSubmit) {
          btnSubmit.disabled = false;
          btnSubmit.textContent = "Salvar Atendimento";
        }
      }
    });
  } else {
    console.error("Formulário não encontrado: form.form-container");
  }
</script>
</main>
<%- include('../partials/footer') %>