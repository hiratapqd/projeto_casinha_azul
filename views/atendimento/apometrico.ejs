<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">
<main class="hero">
    <h1>Ficha de Atendimento - Apometria</h1>
    <form action="/atendimento/salvar" method="POST" class="form-container" id="atendimentoForm">
        <input type="hidden" name="tipo" value="apometrico">
        
        <div class="form-row">
            <div class="form-group">
                <label>Data:</label>
                <input type="date" name="data" id="campo_data" required>
            </div>
            <div class="form-group flex-2">
                <label>CPF:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" placeholder="Apenas números" required autocomplete="off">
            </div>
        </div>

        <div class="form-row">
          <div class="form-group">
              <label>Nome:</label>
              <input type="text" name="nome_assistido" id="campo_nome" required>
          </div>
          <div class="form-group">
              <label>Idade:</label>
              <input type="text" name="idade_assistido" id="campo_idade">
          </div>
          <div class="form-group">
              <label>Religião:</label>
              <input type="text" name="religiao_assistido" id="campo_religiao">
          </div>
        </div>

        <div class="form-group">
            <label>Terapeuta Responsável:</label>
            <input type="text" name="voluntario" required>
        </div>

        <div class="form-group">
            <label>Observações:</label>
            <textarea name="observacoes" rows="4"></textarea>
        </div><br><br>

        <button type="submit" class="btn-primary">Finalizar o Atendimento</button>
    </form>

    <section class="historico-section" style="margin-top: 30px;">
        <h2>Histórico de Atendimentos</h2>
        <div id="historicoContainer" style="background: #fff; padding: 15px; border: 1px solid #ddd; border-radius: 8px;">
            <table class="historico-table" id="tabela-historico" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f4f4f4; text-align: left;">
                        <th style="padding: 10px; border-bottom: 2px solid #ddd;">Data</th>
                        <th style="padding: 10px; border-bottom: 2px solid #ddd;">Observações</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="2" id="msg_status" style="text-align:center; padding: 20px;">Digite o CPF para carregar os dados.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // 1. CONFIGURAÇÃO DA DATA ATUAL
  const inputData = document.getElementById('campo_data');
  if (inputData) inputData.value = new Date().toISOString().split('T')[0];

  // 2. FUNÇÃO RENDERIZAR TABELA (Ajustada para o novo ID)
  function renderizarTabela(lista) {
    const corpoTabela = document.querySelector('#tabela-historico tbody');
    if (!corpoTabela) return;

    corpoTabela.innerHTML = ''; // Limpa a mensagem inicial ou dados antigos

    if (!lista || lista.length === 0) {
      corpoTabela.innerHTML = '<tr><td colspan="2" style="text-align:center; padding: 10px;">Nenhum atendimento anterior encontrado.</td></tr>';
      return;
    }

    lista.forEach(item => {
      const dataFormatada = new Date(item.data).toLocaleDateString('pt-BR');
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td style="padding: 10px; border-bottom: 1px solid #eee;">${dataFormatada}</td>
        <td style="padding: 10px; border-bottom: 1px solid #eee;">${item.observacoes || ''}</td>
      `;
      corpoTabela.appendChild(tr);
    });
  }

  // 3. EVENTO DE BUSCA AO SAIR DO CAMPO CPF
  document.getElementById('cpf_assistido').addEventListener('blur', async function() {
      const cpf = this.value.trim().replace(/\D/g, '');
      if (cpf.length < 11) return;

      try {
          console.log("LOG: Buscando dados para o CPF:", cpf);

          // Chamada 1: Dados Cadastrais
          const resDados = await fetch(`/api/dados-assistido/${cpf}`).then(r => r.json());
          if (resDados) {
              document.getElementById('campo_nome').value = resDados.nome_assistido || "";
              document.getElementById('campo_religiao').value = resDados.religiao_assistido || "";
              
              if (resDados.data_nascimento_assistido) {
                  const dataNasc = new Date(resDados.data_nascimento_assistido);
                  const hoje = new Date();
                  let idade = hoje.getFullYear() - dataNasc.getFullYear();
                  if (hoje < new Date(hoje.getFullYear(), dataNasc.getMonth(), dataNasc.getDate())) idade--;
                  document.getElementById('campo_idade').value = idade + " Anos";
              }
          }

          // Chamada 2: Histórico (Atendimentos anteriores)
          const resHist = await fetch(`/api/historico/apometrico/${cpf}`).then(r => r.json());
          console.log("LOG: Queixa recebida:", resHist.queixa_atual);

          // Inserir a queixa no campo de Observações
          if (resHist.queixa_atual) {
              const campoObs = document.querySelector('textarea[name="observacoes"]');
/*               if (campoObs) {
                  // Adiciona a queixa no início das observações
                  campoObs.value = `QUEIXA DO DIA: ${resHist.queixa_atual}\n\n`;
              } */
                    if (campoObs) {
                    const queixa = resHist.queixa_atual || "Não informada";
                    
                    // Monta o texto estruturado
                    const textoEstruturado = `QUEIXA DO DIA: ${queixa}\n` +
                                            `-----------------------------\n` +
                                            `OBSERVAÇÕES DO TERAPEUTA:\n`;

                    // Só preenche se o campo estiver vazio para não apagar algo que o terapeuta já começou a escrever
                    if (campoObs.value.trim() === "") {
                        campoObs.value = textoEstruturado;
                    }
                    }
          }

          renderizarTabela(resHist.historico || []);
/*           const resHist = await fetch(`/api/historico/apometrico/${cpf}`).then(r => r.json());
          console.log("LOG: Histórico recebido:", resHist);

          // Renderiza os dados na tabela que criamos acima
          renderizarTabela(resHist.historico || []);
 */
      } catch (err) {
          console.error('Erro ao carregar dados:', err);
      }
  });

  // 4. ENVIO DO FORMULÁRIO
  const formAtend = document.getElementById('atendimentoForm');
  if (formAtend) {
    formAtend.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button');
      btn.disabled = true;
      try {
        const formData = new URLSearchParams(new FormData(e.target));
        const resp = await fetch(e.target.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: formData
        });
        if (!resp.ok) throw new Error();
        await Swal.fire('Sucesso', 'Atendimento finalizado com sucesso!', 'success');
        window.location.reload();
      } catch (err) {
        Swal.fire('Erro', 'Falha ao salvar o atendimento.', 'error');
        btn.disabled = false;
      }
    });
  }
</script>

<%- include('../partials/footer') %>