<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">
<main class="hero">
    <h1>Ficha de Atendimento - Apometria</h1>
    <form action="/atendimento/salvar" method="POST" class="form-container" id="atendimentoForm">
        <input type="hidden" name="tipo" value="apometrico">
        
        <div class="form-row">
            <div class="form-group">
                <label>Data:</label>
                <input type="date" name="data" id="campo_data" required>
            </div>
            <div class="form-group flex-2">
                <label>CPF:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" placeholder="Apenas números" required autocomplete="off">
            </div>
        </div>

        <div class="form-row">
          <div class="form-group">
              <label>Nome:</label>
              <input type="text" name="nome_assistido" id="campo_nome" required>
          </div>
          <div class="form-group">
              <label>Idade:</label>
              <input type="text" name="idade_assistido" id="campo_idade">
          </div>
          <div class="form-group">
              <label>Religião:</label>
              <input type="text" name="religiao_assistido" id="campo_religiao">
          </div>
        </div>

        <div class="form-group">
            <label>Terapeuta Responsável:</label>
            <input type="text" name="voluntario" required>
        </div>

        <div class="form-group">
            <label>Observações:</label>
            <textarea name="observacoes" rows="4"></textarea>
        </div>

        <button type="submit" class="btn-primary">Finalizar o Atendimento</button>
    </form>

    <section class="historico-section" style="margin-top: 30px;">
        <h2>Histórico de Atendimentos</h2>
        <div id="historicoContainer" style="background: #fff; padding: 15px; border: 1px solid #ddd; border-radius: 8px;">
            <p id="msg_status">Digite o CPF para carregar os dados.</p>
        </div>
    </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // 1. Definição da Data de Hoje
  document.getElementById('campo_data').value = new Date().toISOString().split('T')[0];

  // 2. FUNÇÃO QUE DESENHA A TABELA (Definida primeiro!)
  const renderizarTabelaApometria = (lista) => {
    const container = document.getElementById('historicoContainer');
    console.log("Renderizando lista:", lista);
    
    if (!lista || lista.length === 0) {
      container.innerHTML = '<p>Nenhum histórico encontrado para este CPF.</p>';
      return;
    }

    let html = '<table style="width:100%; border-collapse: collapse; margin-top:10px;">';
    html += '<tr style="background:#f4f4f4"><th style="padding:8px; border:1px solid #ddd;">Data</th><th style="padding:8px; border:1px solid #ddd;">Terapeuta</th><th style="padding:8px; border:1px solid #ddd;">Observações</th></tr>';
    
    lista.forEach(item => {
      const dataF = item.data ? new Date(item.data).toLocaleDateString('pt-BR') : '---';
      html += `<tr>
        <td style="border:1px solid #ddd; padding:8px;">${dataF}</td>
        <td style="border:1px solid #ddd; padding:8px;">${item.voluntario || ''}</td>
        <td style="border:1px solid #ddd; padding:8px;">${item.observacoes || ''}</td>
      </tr>`;
    });
    
    html += '</table>';
    container.innerHTML = html;
  };

  // 3. EVENTO DE BUSCA (Chama a função acima)
  document.getElementById('cpf_assistido').addEventListener('blur', async function() {
    const cpfRaw = this.value.trim();
    const cpf = cpfRaw.replace(/\D/g, ''); // Limpa para ficar só números
    
    if (cpf.length < 11) {
        console.log("CPF incompleto, aguardando...");
        return;
    }

    const container = document.getElementById('historicoContainer');
    container.innerHTML = '<p>Buscando dados...</p>';

    try {
      // Busca Dados Cadastrais e Histórico em paralelo
      const [resDados, resHist] = await Promise.all([
        fetch(`/api/dados-assistido/${cpf}`).then(r => r.json()),
        fetch(`/api/historico/apometrico/${cpf}`).then(r => r.json())
      ]);

      console.log("Dados do Assistido:", resDados);
      console.log("Dados do Histórico:", resHist);

      // Preenche os campos de texto
      document.getElementById('campo_nome').value = resDados.nome || "";
      document.getElementById('campo_idade').value = resDados.idade || "";
      document.getElementById('campo_religiao').value = resDados.religiao || "";

      // Renderiza a tabela usando a função definida no passo 2
      // Note que usamos resHist.historico pois é assim que o seu Controller envia
      renderizarTabelaApometria(resHist.historico || []);

    } catch (err) {
      console.error('Erro na requisição AJAX:', err);
      container.innerHTML = '<p style="color:red;">Erro ao carregar dados do servidor.</p>';
    }
  });

  // 4. ENVIO DO FORMULÁRIO
  document.getElementById('atendimentoForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button');
    btn.disabled = true;
    try {
      const formData = new URLSearchParams(new FormData(e.target));
      const resp = await fetch(e.target.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: formData
      });
      if (!resp.ok) throw new Error('Erro ao salvar');
      await Swal.fire('Sucesso', 'Atendimento salvo!', 'success');
      window.location.reload();
    } catch (err) {
      Swal.fire('Erro', err.message, 'error');
      btn.disabled = false;
    }
  });
</script>
<%- include('../partials/footer') %>