<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">
<main class="hero">
    <h1>Ficha de Atendimento - Reiki</h1>
    
    <form action="/atendimento/reiki" method="POST" class="form-container" id="atendimentoForm">
        <input type="hidden" name="tipo" value="reiki">
        
        <div class="form-row">
            <div class="form-group">
                <label>Data:</label>
                <input type="date" name="data" id="campo_data" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            <div class="form-group flex-2">
                <label>CPF:</label>
                <input type="text" id="cpf_assistido" name="cpf_assistido" placeholder="Apenas números" required autocomplete="off">
            </div>
        </div>
        
        <div class="form-row">
            <div class="form-group">
                <label>Nome:</label>
                <input type="text" name="nome_assistido" id="campo_nome" required>
            </div>

            <div class="form-group">
                <label>Terapeuta Responsável:</label>
                <input type="text" name="voluntario" required>
            </div>
        </div>

        <div class="form-group">
            <label>Observações:</label>
            <textarea name="observacoes" id="campo_observacoes" rows="4"></textarea>
        </div><br><br>

        <button type="submit" class="btn-primary">Finalizar Atendimento</button>
    </form>

    <section class="historico-section" style="margin-top: 30px;">
        <h2>Histórico de Reiki</h2>
        <div style="background: #fff; padding: 15px; border: 1px solid #ddd; border-radius: 8px;">
            <table class="historico-table" id="tabela-historico" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f4f4f4; text-align: left;">
                        <th style="padding: 10px; border-bottom: 2px solid #ddd;">Data</th>
                        <th style="padding: 10px; border-bottom: 2px solid #ddd;">Observações</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="2" style="text-align:center; padding: 20px;">Digite o CPF para carregar o histórico.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // Função para renderizar a tabela
  function renderizarTabela(lista) {
    const corpoTabela = document.querySelector('#tabela-historico tbody');
    if (!corpoTabela) return;
    corpoTabela.innerHTML = '';
    if (!lista || lista.length === 0) {
      corpoTabela.innerHTML = '<tr><td colspan="2" style="text-align:center; padding: 10px;">Nenhum atendimento anterior.</td></tr>';
      return;
    }
    lista.forEach(item => {
      const tr = document.createElement('tr');
      tr.innerHTML = `<td style="padding: 10px; border-bottom: 1px solid #eee;">${new Date(item.data).toLocaleDateString('pt-BR')}</td>
                      <td style="padding: 10px; border-bottom: 1px solid #eee;">${item.observacoes || ''}</td>`;
      corpoTabela.appendChild(tr);
    });
  }

  // Evento de busca por CPF
  document.getElementById('cpf_assistido').addEventListener('blur', async function() {
    const cpf = this.value.trim().replace(/\D/g, '');
    if (cpf.length < 11) return;

    try {
      // 1. Busca dados do assistido (Nome)
      // CORRIGIDO: Rota exata que funciona na Apometria
      const respDados = await fetch(`/api/dados-assistido/${cpf}`).then(r => r.json());
      if (respDados) {
        document.getElementById('campo_nome').value = respDados.nome_assistido || "";
      }

      // 2. Busca Histórico e Queixa
      const respHist = await fetch(`/api/historico/reiki/${cpf}`).then(r => r.json());
      
      // Coloca a queixa nas observações
/*       if (respHist.queixa_atual) {
        const campoObs = document.getElementById('campo_observacoes');
        if (campoObs && !campoObs.value.includes("QUEIXA DO DIA:")) {
            campoObs.value = `QUEIXA DO DIA: ${respHist.queixa_atual}\n\n` + campoObs.value;
        }
      }
 */
      renderizarTabela(respHist.historico);
    } catch (err) {
      console.error('Erro ao buscar dados:', err);
    }
  });

  // Envio do Form
  document.getElementById('atendimentoForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button');
    btn.disabled = true;
    try {
      const formData = new URLSearchParams(new FormData(e.target));
      const r = await fetch(e.target.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: formData
      });
      if (!r.ok) throw new Error();
      await Swal.fire('Sucesso', 'Atendimento de Reiki salvo!', 'success');
      window.location.reload();
    } catch (err) {
      Swal.fire('Erro', 'Erro ao salvar.', 'error');
      btn.disabled = false;
    }
  });
</script>